# Copy to a local override or set via --dart-define when building.
# Telegram (TDLib) — same semantics as the legacy Vite app
TELEGRAM_API_ID=...
TELEGRAM_API_HASH=...

# Sync / indexing (aligned with Oxplayer backend)
# Quote the value: unquoted # starts a comment in dotenv, so INDEX_TAG=#seeOnTV would be empty.
BOT_USERNAME="@..."
# Membership gate (optional — leave empty to skip in dev). Must match backend/captioner env when set.
PROVIDER_BOT_USERNAME="@..."
REQUIRED_CHANNEL_USERNAME="@..."

# SubDL (optional). Subtitle search in the internal player is disabled when empty.
SUBDL_API_KEY=

# Oxplayer HTTP API (ngrok sync from `pnpm docker:dev` updates OXPLAYER_API_BASE_URL when configured)
OXPLAYER_API_BASE_URL=""
OXPLAYER_TELEGRAM_WEBAPP_SHORT_NAME=""
# Optional fallback when short name is not configured on bot
# Must be a valid Web App URL configured for your bot/domain.
OXPLAYER_TELEGRAM_WEBAPP_URL="https://t.me/..."
