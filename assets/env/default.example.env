# Copy this file to `assets/env/default.env` and fill local secrets.
# Telegram (TDLib) — same semantics as the legacy Vite app
TELEGRAM_API_ID=YOUR_TELEGRAM_API_ID
TELEGRAM_API_HASH=YOUR_TELEGRAM_API_HASH

# Sync / indexing (matches tv-app-old)
# Quote the value: unquoted # starts a comment in dotenv, so INDEX_TAG=#seeOnTV would be empty.
INDEX_TAG="#seeOnTV"
BOT_USERNAME="@seeOnTVbot"

# TV API backend
# `npm run dev:tv:ngrok` temporarily overwrites this value while running.
TV_APP_API_BASE_URL="http://localhost:4040"
TV_APP_WEBAPP_SHORT_NAME="SEETV"
# Optional fallback when short name is not configured on bot
# Must be a valid Web App URL configured for your bot/domain.
TV_APP_WEBAPP_URL="https://t.me/your_bot/SEETV"
