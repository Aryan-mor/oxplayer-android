<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--
        Expose files in:
        /storage/emulated/0/Android/data/<applicationId>/files/Downloads/
        via FileProvider URI.
    -->
    <external-files-path
        name="external_downloads"
        path="Downloads/" />

    <!--
        TDLib saves under getApplicationSupportDirectory()/tdlib_files/ which on
        Android is Context.getFilesDir()/tdlib_files/ (path_provider_android).
        External players need this root for FileProvider URIs.
    -->
    <files-path
        name="tdlib_files"
        path="tdlib_files/" />
</paths>
