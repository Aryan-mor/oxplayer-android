<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- TV focus: cyan ring + soft fill + outer glow (brand highlight #38BDF8) -->
  <item android:state_focused="true">
    <layer-list>
      <item>
        <shape android:shape="oval">
          <solid android:color="#6638BDF8" />
        </shape>
      </item>
      <item
          android:bottom="4dp"
          android:left="4dp"
          android:right="4dp"
          android:top="4dp">
        <shape android:shape="oval">
          <stroke
              android:width="3dp"
              android:color="#FF38BDF8" />
          <solid android:color="#38000000" />
        </shape>
      </item>
    </layer-list>
  </item>
  <item android:state_pressed="true">
    <shape android:shape="oval">
      <solid android:color="#5038BDF8" />
    </shape>
  </item>
  <!-- Same ring thickness when unfocused so focus does not resize the control -->
  <item>
    <shape android:shape="oval">
      <stroke
          android:width="3dp"
          android:color="#00000000" />
      <solid android:color="#00000000" />
    </shape>
  </item>
</selector>
