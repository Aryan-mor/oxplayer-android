{
  "name": "tv-app",
  "private": true,
  "scripts": {
    "flutter": "flutter",
    "get": "flutter pub get",
    "codegen": "dart run build_runner build --delete-conflicting-outputs",
    "watch": "dart run build_runner watch --delete-conflicting-outputs",
    "dev": "flutter run",
    "build:apk": "flutter build apk",
    "build:apk:release": "flutter build apk --release",
    "android:install:release": "adb -d install -r build/app/outputs/flutter-apk/app-release.apk",
    "release:install": "flutter pub get && dart run build_runner build --delete-conflicting-outputs && flutter build apk --release && adb -d install -r build/app/outputs/flutter-apk/app-release.apk",
    "analyze": "flutter analyze"
  }
}
