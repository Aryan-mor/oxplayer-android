{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Flutter Android Debug",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\scripts\\run_flutter_android_debug.ps1",
        "-Mode",
        "attach"
      ],
      "isBackground": true
    },
    {
      "label": "Reinstall Flutter Android Debug",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\scripts\\run_flutter_android_debug.ps1",
        "-Mode",
        "reinstall"
      ],
      "isBackground": true
    },
    {
      "label": "Collect Android Crash Logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\scripts\\collect_android_crash_logs.ps1"
      ]
    }
  ]
}
